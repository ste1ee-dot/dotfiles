{
    "layer": "top",
    "position": "top",
    "height": 32,
    "//width": 1908,
    "modules-left": [
        "wlr/taskbar",
        "custom/weather"
    ],
    "modules-center": [],
    "modules-right": [
        "pulseaudio",
        "memory",
        "temperature",
        "battery",
        "clock#date",
        "clock#time",
        "tray"
    ],
    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 14,
        "icon-theme": "Numix-Circle",
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-middle": "close"
    },
    "battery": {
        "interval": 10,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "пѓ§{icon}{capacity}%",
        "format-discharging": "{icon}{capacity}%",
        "format-icons": [
            "п‰ѓ ",
            "п‰„ ",
            "п‰‚ ",
            "п‰Ѓ ",
            "п‰Ђ "
        ],
        "tooltip": true
    },
    "clock#time": {
        "interval": 1,
        "format": "{:%H:%M}",
        "tooltip": false
    },
    "clock#date": {
        "interval": 10,
        "format": "пЃі {:%e %b %Y}",
        "tooltip-format": "{:%e %B %Y}"
    },
    "cpu": {
        "interval": 5,
        "format": "п’ј {usage}%({load}){min_frequency}/{avg_frequency}/{max_frequency}GHz",
        "states": {
            "warning": 70,
            "critical": 90
        }
    },
    "memory": {
        "interval": 5,
        "format": "п‹› {}%",
        "states": {
            "warning": 70,
            "critical": 90
        }
    },
    "disk": {
        "interval": 30,
        "format": "у°‘№ {percentage_used}%",
        "states": {
            "warning": 90,
            "critical": 95
        }
    },
    "network": {
        "interval": 5,
        "interface": "wlp1s0f0",
        "format-wifi": "п‡« {signalStrength}% \"{essid}\"",
        "format-ethernet": "пћ–  {ipaddr}",
        "format-disconnected": "вљ  Disconnected",
        "tooltip-format": "{ifname}\nп‚“  {bandwidthUpBytes}\nпЂ™  {bandwidthDownBytes}",
        "tooltip-format-wifi": "{ifname}\nп‚“  {bandwidthUpBytes}\nпЂ™  {bandwidthDownBytes}\nFrequency: {frequency}",
        "tooltip-format-disconnected": "N/a",
        "//tooltip-format": "{ifname}: {ipaddr}"
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "{icon} пЉ”{volume}%",
        "format-muted": "пЂ¦",
        "format-icons": {
            "headphone": "пЂҐ",
            "hands-free": "п–ђ",
            "headset": "пЂҐ",
            "phone": "п‚•",
            "portable": "п‚•",
            "car": "п†№",
            "default": [
                "пЂ§",
                "пЂЁ"
            ]
        },
        "scroll-step": 1,
        "on-click": "pavucontrol"
    },
    "temperature": {
        "//hwmon-path-abs": "/sys/class/thermal/thermal_zone0/hwmon1",
        "//input-filename": "temp",
        "critical-threshold": 80,
        "interval": 5,
        "format": "{icon}{temperatureC}В°C",
        "format-icons": [
            "п‹‹",
            "п‹Љ",
            "п‹‰",
            "п‹€",
            "п‹€"
        ],
        "tooltip": true
    },
    "tray": {
        "icon-size": 15,
        "spacing": 10
    },
    "custom/vpn": {
        "format": "{}",
        "exec": "~/.config/waybar/bin/wireguard.sh",
        "return-type": "json",
        "interval": 5
    },
    "custom/idling": {
        "format": "{}",
        "exec": "~/.config/waybar/bin/idling.sh",
        "return-type": "json",
        "interval": 1
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "пЃ®",
            "deactivated": "пЃ°"
        }
    },
    "custom/syncthing": {
        "format": "{}",
        "exec": "~/.config/waybar/bin/syncthing.sh",
        "return-type": "json",
        "interval": 1
    },
    "custom/weather": {
        "format": "{}",
        "exec": "~/.config/waybar/bin/weather.sh",
        "return-type": "json",
        "interval": 60
    }
}
